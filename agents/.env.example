# DeepSeek Anthropic-compatible endpoint for Claude Agent SDK.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=your-deepseek-api-key
CLAUDE_AGENT_MODEL=deepseek-v4-pro

# Required by podcast-to-article/scripts/fetch_transcript.py.
SERPAPI_API_KEY=your-serpapi-api-key

# Optional fallback when SerpApi cannot return YouTube transcripts.
# Requires yt-dlp in the active Python environment.
TRANSCRIBER_BACKEND=serpapi
ALIYUN_API_KEY=your-dashscope-api-key
ALIYUN_ASR_MODEL=fun-asr
ALIYUN_ASR_API_BASE=https://dashscope.aliyuncs.com/api/v1
# Optional: keep downloaded audio for debugging instead of using a temp dir.
# ALIYUN_ASR_AUDIO_DIR=output/asr-audio
# ALIYUN_ASR_KEEP_AUDIO=false
